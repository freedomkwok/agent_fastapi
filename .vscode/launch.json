{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Agent FastAPI: launch uvicorn",
      "type": "debugpy",
      "request": "launch",
      "module": "uvicorn",
      "args": [
        "agent_fastapi.main:app",
        "--reload",
        "--host",
        "0.0.0.0",
        "--port",
        "8080"
      ],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "justMyCode": false,
      "envFile": "${workspaceFolder}/../imp_agent_core/.env"
    },
    {
      "name": "Agent FastAPI: attach debugpy 5678",
      "type": "debugpy",
      "request": "attach",
      "connect": {
        "host": "127.0.0.1",
        "port": 5678
      },
      "justMyCode": false,
      "pathMappings": [
        {
          "localRoot": "${workspaceFolder}",
          "remoteRoot": "${workspaceFolder}"
        },
        {
          "localRoot": "${workspaceFolder}/../imp_agent_core",
          "remoteRoot": "${workspaceFolder}/../imp_agent_core"
        }
      ]
    }
  ]
}
