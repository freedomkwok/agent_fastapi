{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Agent FastAPI: uvicorn debugpy",
      "type": "shell",
      "command": "uv run --extra dev python -m debugpy --listen 5678 -m uvicorn agent_fastapi.main:app --reload --host 0.0.0.0 --port 8080",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "isBackground": true,
      "problemMatcher": {
        "pattern": {
          "regexp": ".",
          "file": 1,
          "location": 2,
          "message": 3
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".*debugpy.*",
          "endsPattern": ".*Application startup complete.*"
        }
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      }
    }
  ]
}
